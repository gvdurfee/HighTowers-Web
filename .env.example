# Mapbox access token for satellite imagery and maps.
# Get a token at https://account.mapbox.com/
# Add this file as .env with your actual token before running the app.
#
# The Node server (FAA MTR backend) reads this same variable to proxy Mapbox Static Images
# for PDF export — browser fetch() to api.mapbox.com is usually blocked by CORS.
# Use: npm run dev:all   (or run `npm run server` in one terminal and `npm run dev` in another)
# so /api/mapbox-static is available when you export the report from the web app.
VITE_MAPBOX_ACCESS_TOKEN=your_mapbox_token_here

# --- Server only (Copernicus Data Space — “recent imagery overlay” in Survey Location) ---
# Create an OAuth client: https://shapps.dataspace.copernicus.eu/dashboard/#/account/settings
# See HighTowers-Web/server/README.md
# CDSE_OAUTH_CLIENT_ID=
# CDSE_OAUTH_CLIENT_SECRET=
