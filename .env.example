# Mapbox access token for satellite imagery and maps.
# Get a token at https://account.mapbox.com/
# Add this file as .env with your actual token before running the app.
#
# The Node server (FAA MTR backend) reads this same variable to proxy Mapbox Static Images
# for PDF export — browser fetch() to api.mapbox.com is usually blocked by CORS.
# Use: npm run dev:all   (or run `npm run server` in one terminal and `npm run dev` in another)
# so /api/mapbox-static is available when you export the report from the web app.
# Copy this file to `.env` and replace the placeholder with your real token (never commit `.env`).
VITE_MAPBOX_ACCESS_TOKEN=

# Optional: public URL of the Node API when the web app is hosted without a same-origin proxy
# (e.g. GitHub Pages). Leave empty locally — Vite proxies /api to port 3001.
# VITE_API_BASE_URL=https://your-api.example.com

# --- Server only: Copernicus “recent imagery overlay” (Fly-Over → Load recent imagery overlay) ---
# Required in your real `.env` (project root, same file as VITE_*). Without both lines, the API
# returns an error when you click the overlay button. Create an OAuth client:
# https://shapps.dataspace.copernicus.eu/dashboard/#/account/settings
# Then uncomment and fill in `.env` (not just this example file) and restart `npm run dev:all`.
# CDSE_OAUTH_CLIENT_ID=your_client_id
# CDSE_OAUTH_CLIENT_SECRET=your_client_secret
